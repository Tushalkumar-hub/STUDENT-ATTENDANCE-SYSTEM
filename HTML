<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GOLD Shop System</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="styles.css">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-light bg-light">
        <div class="container">
            <a class="navbar-brand text-warning" href="#home">GOLD Shop</a>
            <ul class="navbar-nav ms-auto">
                <li class="nav-item"><a class="nav-link" href="#home">Home</a></li>
                <li class="nav-item"><a class="nav-link" href="#listing">Shop</a></li>
                <li class="nav-item"><a class="nav-link" href="#cart">Cart (<span id="cart-count">0</span>)</a></li>
                <li class="nav-item"><a class="nav-link" href="#about">About</a></li>
            </ul>
            <input type="text" id="search" placeholder="Search products..." class="form-control ms-3" style="width: 200px;">
        </div>
    </nav>

    <div id="home" class="section">
        <div class="hero bg-warning text-white text-center py-5">
            <h1>Welcome to GOLD Shop</h1>
            <p>Exquisite gold jewelry for every occasion</p>
        </div>
        <div class="container mt-4">
            <h2>Featured Products</h2>
            <div class="row" id="featured-products">
                <div class="col-md-4">
                    <div class="card product-card">
                        <img src="images/ring.jpg" class="card-img-top" alt="Gold Ring">
                        <div class="card-body">
                            <h5>Gold Ring</h5>
                            <p>$500</p>
                            <button class="btn btn-warning add-to-cart" data-product="Gold Ring" data-price="500">Add to Cart</button>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card product-card">
                        <img src="images/necklace.jpg" class="card-img-top" alt="Gold Necklace">
                        <div class="card-body">
                            <h5>Gold Necklace</h5>
                            <p>$800</p>
                            <button class="btn btn-warning add-to-cart" data-product="Gold Necklace" data-price="800">Add to Cart</button>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card product-card">
                        <img src="images/watch.jpg" class="card-img-top" alt="Gold Watch">
                        <div class="card-body">
                            <h5>Gold Watch</h5>
                            <p>$1200</p>
                            <button class="btn btn-warning add-to-cart" data-product="Gold Watch" data-price="1200">Add to Cart</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div id="listing" class="section container mt-4" style="display: none;">
        <h2>Product Listing</h2>
        <div class="row">
            <div class="col-md-3">
                <h5>Filters</h5>
                <select class="form-select">
                    <option>All Categories</option>
                    <option>Rings</option>
                    <option>Necklaces</option>
                </select>
            </div>
            <div class="col-md-9">
                <div class="row" id="product-list">
            
                </div>
            </div>
        </div>
    </div>

    <div id="detail" class="section container mt-4" style="display: none;">
        <h2>Product Detail</h2>
        <div class="row">
            <div class="col-md-6">
                <img src="images/ring.jpg" class="img-fluid" alt="Product">
            </div>
            <div class="col-md-6">
                <h3>Gold Ring</h3>
                <p>Description: Elegant 18k gold ring.</p>
                <p>$500</p>
                <button class="btn btn-warning add-to-cart" data-product="Gold Ring" data-price="500">Add to Cart</button>
            </div>
        </div>
    </div>

    <div id="search-results" class="section container mt-4" style="display: none;">
        <h2>Search Results</h2>
        <div class="row" id="search-list">
        </div>
    </div>

    <div id="cart" class="section container mt-4" style="display: none;">
        <h2>Shopping Cart</h2>
        <table class="table">
            <thead>
                <tr><th>Product</th><th>Price</th><th>Action</th></tr>
            </thead>
            <tbody id="cart-items"></tbody>
        </table>
        <p>Total: $<span id="total">0</span></p>
        <button class="btn btn-warning" onclick="showCheckout()">Proceed to Checkout</button>
    </div>

    <div id="checkout" class="section container mt-4" style="display: none;">
        <h2>Checkout</h2>
        <form>
            <div class="mb-3"><input type="text" class="form-control" placeholder="Name"></div>
            <div class="mb-3"><input type="text" class="form-control" placeholder="Address"></div>
            <div class="mb-3"><input type="text" class="form-control" placeholder="Payment (Simulated)"></div>
            <button class="btn btn-warning" type="button" onclick="alert('Order Placed!')">Place Order</button>
        </form>
    </div>

    <div id="about" class="section container mt-4" style="display: none;">
        <h2>About Us</h2>
        <p>We specialize in premium gold jewelry.</p>
        <form>
            <div class="mb-3"><input type="text" class="form-control" placeholder="Name"></div>
            <div class="mb-3"><textarea class="form-control" placeholder="Message"></textarea></div>
            <button class="btn btn-warning">Send</button>
        </form>
    </div>

    <footer class="bg-dark text-white text-center py-3">© 2023 GOLD Shop</footer>
    <script src="script.js"></script>
</body>
</html>